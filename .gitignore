# =================================================================
# MONOREPO SWWORKPLACE - CONFIGURACIÓN PROFESIONAL
# =================================================================

# ---------- IDENTIDAD DEL SERVIDOR (No rastrear backups de emergencia) ----------
.git_corrupto/
06_Archive/

# ---------- ENTORNOS DE EJECUCIÓN (Delegar a 05_Runtime) ----------
.venv/
venv/
**/venv/
**/env/
node_modules/
.ipynb_checkpoints/

# ---------- ARTEFACTOS DE IA Y HARDWARE (Protección RTX 5070) ----------
# No subir pesos de modelos ni datasets que deben ir en 03_Data_Lake o 04_Models
*.pth
*.onnx
*.bin
*.model
*.weights
**/datasets/
**/outputs/

# ---------- BACKEND (Java / Spring Boot / Maven) ----------
target/
**/target/
*.jar
*.war
*.ear
.mvn/
.factorypath

# Archivos generados por compilación Java
*.class

# Logs de ejecución Spring Boot
logs/
*.log

# Bases de datos embebidas (H2 / SQLite)
*.db
*.mv.db
*.trace.db

# ---------- IDEs (Configuración local de desarrollador) ----------
.idea/
*.iml
.vscode/
.project
.classpath
.settings/

# ---------- FRONTEND (Angular / Node) ----------
dist/
**/dist/
.angular/
npm-debug.log*

# ---------- PYTHON CACHE & BUILD ----------
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
*.so
build/
**/build/

# ---------- ARCHIVOS DE SISTEMA Y MULTIMEDIA ----------
.DS_Store
Thumbs.db
*.mp3
*.wav
*.mp4
*.avi

# ---------- SECRETOS Y CONFIGURACIÓN LOCAL (Security by Design) ----------
.env
.env.*
!.env.example
secrets.yml
*.pem
*.key
*.p12
*.jks

# ---------- CONFIGURACIÓN LOCAL SPRING ----------
# Archivos de configuración locales que pueden contener credenciales
application-local.properties
application-local.yml
application-dev.properties
application-dev.yml

# ---------- DOCUMENTACIÓN Y DISEÑO (IEEE 830) ----------
# Permitir solo Markdown para documentación técnica
!*.md
